{
  "name": "vue-snake-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "lint": "pnpm typecheck && pnpm format:check && pnpm test",
    "ci": "pnpm lint && pnpm build",
    "check": "pnpm typecheck && pnpm format:check && pnpm test"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.23.0"
}
